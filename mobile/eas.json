{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "stage"
    },
    "stage-testflight": {
      "autoIncrement": true,
      "distribution": "store",
      "channel": "stage",
      "environment": "preview"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "stage-testflight": {
      "ios": {
        "ascAppId": "6765567210"
      }
    },
    "production": {
      "ios": {
        "ascAppId": "6765567210"
      }
    }
  }
}
