{
  "expo": {
    "name": "CutPlate AI",
    "slug": "cutplate-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cutplate",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#edf3ef"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cutplate.cardinal",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cutplate.cardinal",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f4f7f2"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "3e45d52b-5f9e-4a0b-b106-e629e8523142"
      }
    },
    "owner": "d2clan",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3e45d52b-5f9e-4a0b-b106-e629e8523142"
    }
  }
}
