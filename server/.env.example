PORT=4000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
OPENAI_REASONING_EFFORT=low
CORS_ORIGIN=*
# 0 means the first generation waits until the recipes are ready instead of returning a cache-warming timeout.
PLAN_AI_TIMEOUT_MS=0
PLAN_ALLOW_TIMEOUT=false
PLAN_FAST_FIRST=false
PLAN_WEB_SEARCH_DISABLED=false
PLAN_WEB_SEARCH_CONTEXT=medium
ALLOW_LOCAL_RECIPE_FALLBACK=false
PLAN_CACHE_TTL_MS=604800000
PLAN_CACHE_DISABLED=false
EMAIL_CONFIRM_BASE_URL=http://localhost:4000
# Add these for real confirmation emails. Without them, the API logs a local confirmation link.
RESEND_API_KEY=
EMAIL_FROM=CutPlate Cardinal <confirm@yourdomain.com>
